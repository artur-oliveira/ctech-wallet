# Wallet API
# Empty = same-origin. `next dev` proxies /v1.0/* to DEV_API_ORIGIN, which is what
# CloudFront does in front of the ALB in deployed environments — so CORS never applies.
NEXT_PUBLIC_API_URL=
DEV_API_ORIGIN=http://localhost:8000

# OAuth (ctech-account) — the wallet's own public client_id (PKCE)
NEXT_PUBLIC_CTECH_URL=https://accounts.aoctech.app
NEXT_PUBLIC_CTECH_CLIENT_ID=wallet
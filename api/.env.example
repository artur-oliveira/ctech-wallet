# ctech-wallet-api environment variables
# Copy to .env for local development. NEVER commit real secrets or certs.

# Server
PORT=8000
ENVIRONMENT=dev

# AWS
AWS_REGION=us-east-1
TABLE_PREFIX=dev

# For local DynamoDB (DynamoDB Local via docker-compose.test.yml)
# DYNAMODB_ENDPOINT=http://localhost:8123

# Auth — RS256 JWKS from ctech-account
CTECH_URL=https://accounts-api.aoctech.app
# CTECH_JWKS_URL is auto-derived from CTECH_URL if not set
SERVICE_AUDIENCE=https://wallet-api.aoctech.app

# Wallet's own M2M client (confidential, first_party) to call account internal:kyc
WALLET_CLIENT_ID=
WALLET_CLIENT_SECRET=

# PIX / Inter partner bank (mTLS + OAuth2 client_credentials)
#
# The mTLS keypair is NOT configured here — it is read at runtime from SSM
# SecureString: /ctech-wallet/{env}/inter/mtls-cert and .../inter/mtls-key
# (so a bank certificate can be rotated without a redeploy, and the PEM never
# touches the disk). Leave INTER_CLIENT_ID empty in local dev to use the fake
# PIX client.
#
# The short secrets below are exported by start.sh from SSM SecureString in
# deployed environments (same pattern as ctech-account's GOOGLE_CLIENT_SECRET).
INTER_BASE_URL=https://cdpj.partners.bancointer.com.br
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=
INTER_PIX_KEY=
INTER_WEBHOOK_SECRET=

# Cache / lock — Redis/Valkey (optional; falls back to in-memory if unset)
# VALKEY_URL=redis://localhost:6379
